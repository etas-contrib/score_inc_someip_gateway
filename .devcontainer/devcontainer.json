{
    "name": "eclipse-s-core",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "USERNAME": "${localEnv:USER}"
        },
        "options": [
            "--add-host=host.docker.internal:host-gateway"
        ]
    },
    "remoteUser": "${localEnv:USER}",
    "runArgs": [
        "--privileged",
        "--add-host=host.docker.internal:host-gateway",
        "--device=/dev/kvm"
    ],
    "mounts": [
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.qnx/license/licenses",
            "target": "/opt/score_qnx/license/licenses",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.netrc",
            "target": "/home/${localEnv:USER}/.netrc",
            "type": "bind"
        }
    ],
    "initializeCommand": {
        "Make sure QNX licenses exists": "touch -a ~/.qnx/license/licenses",
        "Make sure .netrc exists": "touch -a ~/.netrc"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "detachhead.basedpyright",
                "akiramiyakoda.cppincludeguard",
                "github.vscode-github-actions",
                "streetsidesoftware.code-spell-checker"
            ]
        }
    },
    "postStartCommand": "sudo chmod 666 /dev/kvm && sudo deployment/qemu/setup_bridge.sh"
}

[uid=0 gid=0 perms=0444] /var/ssh/sshd_config = {
Port 22
Protocol 2
HostKey /var/ssh/ssh_host_rsa_key

PasswordAuthentication yes
PermitEmptyPasswords yes
PubkeyAuthentication no
PermitRootLogin yes
PermitUserEnvironment yes
PidFile none
StrictModes no
UseDNS no
LogLevel DEBUG

Subsystem sftp /usr/lib/ssh/sftp-server

# Headroom for rapid test reconnects over the virbr0 bridge.
MaxStartups 100:30:200
LoginGraceTime 30
}

# NOTE: gateway binaries, libs, and configs are placed in the IFS by
# qnx_ifs(srcs=[…]) through the rules_pkg pkg_files targets in BUILD.bazel —
# no explicit "/path=${VAR}" mounts are needed here anymore.

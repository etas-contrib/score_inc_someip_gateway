# Shared IFS content: libs, tools, baked rootfs configs. Per-guest bits
# (kernel block + startup script with hardcoded IP) are in init_a/b.build.

# Shared libraries
/usr/lib/ldqnx-64.so.2=ldqnx-64.so.2
libc.so.6
[type=link] libc.so=libc.so.6
libfsnotify.so.1
libgcc_s.so.1
libm.so
libsecpol.so.1
libtracelog.so.1
libz.so
libc++.so.2
[type=link] libc++.so=libc++.so.2
libsocket.so.4
[type=link] libsocket.so=libsocket.so.4
libxo.so.0
[type=link] libxo.so=libxo.so.0
libslog2.so.1
[type=link] libslog2.so=libslog2.so.1
libslog2parse.so.1
[type=link] libslog2parse.so=libslog2parse.so.1
libqh.so.1
[type=link] libqh.so=libqh.so.1
libcam.so.2
cam-disk.so
io-blk.so
fs-qnx6.so

# PCI / parsing libraries pulled in by the network stack and SD/SSH tools
libpci.so.3.0
libfdt.so.1
libbz2.so.1
liblzma.so.5
libcatalog.so.1
libiconv.so.1
libregex.so.1
libexpat.so.2

# Crypto
libqcrypto.so.1.0
libcrypto.so.3
libssl.so.3
qcrypto-openssl-3.so

# Auth / jail
libjail.so.1
libpam.so.2

# RPC, for tcpdump
librpc.so.2

# Networking modules
io-sock
mods-pci.so
mods-phy.so
devs-vtnet_pci.so

# PCI server + capability handlers
pci-server
pci/pci_hw-Intel_x86.so
pci/pci_slog2.so
pci/pci_cap-0x05.so
pci/pci_cap-0x10.so
pci/pci_cap-0x11.so
pci/pci_strings.so
pci/pci_bkwd_compat.so
pci/pci_debug2.so

# SSH
sshd
ssh
ssh-keygen
/usr/lib/ssh/sftp-server=${QNX_TARGET}/${PROCESSOR}/usr/libexec/sftp-server

# Network userspace tools
if_up
ifconfig
route
sysctl
ping
netstat
tcpdump
hostname

# Core tools / shells / drivers
on
[type=link] waitfor=on
[type=link] ability=on
ksh
pidin
shutdown
toybox
awk
random
getconf
[type=link] setconf=getconf
slog2info
devc-ser8250
devc-pty
fsevmgr
slogger2
pipe
devb-ram
mkqnx6fs
mount

# Symlinks
[type=link] /bin/sh=/proc/boot/ksh
[type=link] /bin/ls=/proc/boot/ls
[type=link] cat=toybox
[type=link] chmod=toybox
[type=link] cp=toybox
[type=link] dd=toybox
[type=link] echo=toybox
[type=link] grep=toybox
[type=link] ln=toybox
[type=link] ls=toybox
[type=link] rm=toybox
[type=link] mkdir=toybox
[type=link] env=toybox
[type=link] mv=toybox
[type=link] pwd=toybox
[type=link] sleep=toybox
[type=link] tail=toybox
[type=link] head=toybox
[type=link] tee=toybox
[type=link] touch=toybox
[type=link] uname=toybox
[type=link] wc=toybox
[type=link] which=toybox
[type=link] whoami=toybox
[type=link] id=toybox
[type=link] sed=toybox
[type=link] sort=toybox
[type=link] find=toybox
[type=link] xargs=toybox
[type=link] date=toybox
[type=link] kill=toybox
[type=link] true=toybox
[type=link] false=toybox
[type=link] test=toybox

# System directories (writable mounts populated by the per-guest startup.sh)
[type=dir] /tmp_discovery
[type=dir] /tmp_ram
[type=dir] /var
[type=dir] /var/db
[gid=0 uid=0 dperms=755 type=dir] /var/chroot/sshd
[gid=0 uid=0 dperms=700 type=dir] /var/ssh

# Baked rootfs configs
[perms=0444] pci_server.cfg = {
[buscfg]
DO_BUS_CONFIG=no

[envars]
PCI_DEBUG_MODULE=pci_debug2.so
PCI_HW_MODULE=pci_hw-Intel_x86.so
PCI_HW_CONFIG_FILE=/proc/boot/pci_hw.cfg
}

[perms=0444] pci_hw.cfg = {
[interrupts]
B0:D17:F0    A    18
B0:D17:F0    B    19
B0:D17:F0    C    16
B0:D17:F0    D    17
B3:D0:F0     A    18
B3:D0:F0     B    19
B3:D0:F0     C    16
B3:D0:F0     D    17
}

[uid=0 gid=0 perms=0444] qcrypto.conf = {
openssl-3 tags=*
}

[uid=0 gid=0 perms=0644] /etc/passwd = {
root::0:0:Superuser:/:/bin/sh
qnxuser::1000:1000:QNX User:/:/bin/sh
sshd::15:6:sshd:/:/bin/false
}

[uid=0 gid=0 perms=0644] /etc/group = {
root::0:root
qnxuser::1000:qnxuser
sshd::6:sshd
}

[uid=0 gid=0 perms=0644] /etc/profile = {
export PATH=/proc/boot:/bin:/usr/bin:/sbin:/usr/sbin
export LD_LIBRARY_PATH=/proc/boot:/usr/lib
export TERM=qansi
export PS1='# '
}

